import time

# colors used for balancing
RED = "RED"
BLACK = "BLACK"

class RBNode:
    # basic node for the tree
    def __init__(self, key, data):
        self.key = key          # (score, unique_id)
        self.data = data        # actual row
        self.color = RED        # new nodes start red
        self.left = None
        self.right = None
        self.parent = None


class RedBlackTree:
    def __init__(self):
        # NIL node replaces None to simplify logic
        self.NIL = RBNode(None, None)
        self.NIL.color = BLACK
        self.root = self.NIL

    # Rotations (used for balancing)
    def left_rotate(self, x):
        # Rotates tree left around node x
        y = x.right
        x.right = y.left

        if y.left != self.NIL:
            y.left.parent = x

        y.parent = x.parent

        # Update root or parent links
        if x.parent is None:
            self.root = y
        elif x == x.parent.left:
            x.parent.left = y
        else:
            x.parent.right = y

        y.left = x
        x.parent = y

    def right_rotate(self, y):
        # Rotates tree right around node y
        x = y.left
        y.left = x.right

        if x.right != self.NIL:
            x.right.parent = y

        x.parent = y.parent

        if y.parent is None:
            self.root = x
        elif y == y.parent.right:
            y.parent.right = x
        else:
            y.parent.left = x

        x.right = y
        y.parent = x

    # Insertions
    def insert(self, key, data):
        # Standard BST insert first
        # Overall insert = O(log N) because tree stays balanced

        node = RBNode(key, data)
        node.left = self.NIL
        node.right = self.NIL

        parent = None
        current = self.root

        # Find the correct position
        while current != self.NIL:
            parent = current
            if node.key < current.key:
                current = current.left
            else:
                current = current.right

        node.parent = parent

        # Insert the node
        if parent is None:
            self.root = node
        elif node.key < parent.key:
            parent.left = node
        else:
            parent.right = node

        # Fix violations
        self.insert_fix(node)

    def insert_fix(self, node):
        # Restores red-black properties after insert
        # Worst case O(log N)

        while node.parent and node.parent.color == RED:

            # Parent is left child
            if node.parent == node.parent.parent.left:
                uncle = node.parent.parent.right

                # Case 1: uncle is red, needs a recolor
                if uncle.color == RED:
                    node.parent.color = BLACK
                    uncle.color = BLACK
                    node.parent.parent.color = RED
                    node = node.parent.parent

                else:
                    # Case 2: Triangle occurs
                    if node == node.parent.right:
                        node = node.parent
                        self.left_rotate(node)

                    # Case 3: Line occurs
                    node.parent.color = BLACK
                    node.parent.parent.color = RED
                    self.right_rotate(node.parent.parent)

            else:
                # Mirror cases
                uncle = node.parent.parent.left

                if uncle.color == RED:
                    node.parent.color = BLACK
                    uncle.color = BLACK
                    node.parent.parent.color = RED
                    node = node.parent.parent

                else:
                    if node == node.parent.left:
                        node = node.parent
                        self.right_rotate(node)

                    node.parent.color = BLACK
                    node.parent.parent.color = RED
                    self.left_rotate(node.parent.parent)

        # Root always needs to be black
        self.root.color = BLACK

    # Top K
    def top_k(self, k):
        # Gets the top k largest values using reverse inorder (IMPORTANT: INSTEAD OF DELETION)
        # Time = O(K + log N)

        if self.root == self.NIL:
            return []

        result = []

        def reverse_inorder(node):
            # Stop if done or empty
            if node == self.NIL or len(result) >= k:
                return

            # Go right first (larger values)
            reverse_inorder(node.right)

            # Add current node
            if len(result) < k:
                result.append(node.data)

            # Then go left
            reverse_inorder(node.left)

        reverse_inorder(self.root)
        return result


# Benchmark
def benchmark_rbtree(dataset, metric_index, k):
    # Build tree and measure time
    tree = RedBlackTree()

    start_build = time.time()

    unique_id = 0
    for row in dataset:
        score = float(row[metric_index])
        key = (score, unique_id)  # tie breaker
        tree.insert(key, row)
        unique_id += 1

    end_build = time.time()

    # Query top k
    start_query = time.time()
    topk = tree.top_k(k)
    end_query = time.time()

    # Build = O(N log N), query = O(K + log N)
    return topk, end_build - start_build, end_query - start_query
